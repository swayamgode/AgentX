# Environment Variables Template
# Copy this to .env.local and fill in your values

# ============================================
# SUPABASE DATABASE
# ============================================
# Get these from: https://supabase.com/dashboard/project/_/settings/database
# Connection Pooling URL (Transaction Mode) - for Prisma migrations
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct Connection URL - for Prisma Client
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# ============================================
# GOOGLE GEMINI API
# ============================================
# Get from: https://aistudio.google.com/app/apikey
# OR configure via /settings page in the app
GOOGLE_API_KEY="your-gemini-api-key-here"

# ============================================
# TWITTER/X API CREDENTIALS
# ============================================
# Get from: https://developer.twitter.com/en/portal/dashboard
TWITTER_API_KEY="your-twitter-api-key"
TWITTER_API_SECRET="your-twitter-api-secret"
TWITTER_ACCESS_TOKEN="your-twitter-access-token"
TWITTER_ACCESS_SECRET="your-twitter-access-secret"

# ============================================
# ENCRYPTION (Optional)
# ============================================
# Used to encrypt API keys in database
# Generate a random 32-character string or leave default
ENCRYPTION_SECRET="agentx-default-secret-key-32ch"

# ============================================
# YOUTUBE API
# ============================================
# Get from: https://console.cloud.google.com/apis/credentials
# Create OAuth 2.0 Client ID for Web Application
YOUTUBE_CLIENT_ID="your-youtube-client-id"
YOUTUBE_CLIENT_SECRET="your-youtube-client-secret"
YOUTUBE_REDIRECT_URI="http://localhost:3000/api/youtube/callback"

# ============================================
# INSTAGRAM/FACEBOOK API
# ============================================
# Get from: https://developers.facebook.com/apps/
# Create a Facebook App with Instagram permissions
INSTAGRAM_APP_ID="your-instagram-app-id"
INSTAGRAM_APP_SECRET="your-instagram-app-secret"
INSTAGRAM_REDIRECT_URI="http://localhost:3000/api/instagram/callback"
